            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson && responseJson.data && responseJson.data.token) {",
                  "    pm.collectionVariables.set(\"jwtToken\", responseJson.data.token);",
                  "    console.log(\"Saved jwtToken:\", responseJson.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
